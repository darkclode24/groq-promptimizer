{
	"manifest_version": 3,
	"name": "Groq Prompt Optimizer",
	"version": "1.0.4",
	"description": "Highlight text, right-click, and optimize your prompt using Groq.",
	"permissions": ["contextMenus", "storage", "activeTab", "scripting", "tabs"],
	"host_permissions": ["https://api.groq.com/*"],
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"css": ["content.css"],
			"js": ["extractors.js", "content.js"]
		}
	],
	"action": {
		"default_popup": "popup.html",
		"default_title": "Groq Prompt Optimizer",
		"default_icon": {
			"128": "icon.png"
		}
	},
	"commands": {
		"optimize-selection": {
			"suggested_key": {
				"default": "Alt+Shift+O",
				"mac": "Command+Shift+O"
			},
			"description": "Optimize the currently selected text with Groq"
		}
	},
	"icons": {
		"128": "icon.png"
	}
}
